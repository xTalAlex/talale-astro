---
import { Icon } from "astro-icon/components";
import Layout from "@src/layouts/Layout.astro";

const title = "Reimposta Password";
const description = "Imposta una nuova password per il tuo account";
---

<Layout title={title} description={description} noindex={true}>
  <div class="container w-full max-w-md px-5 md:mx-auto">
    <h1 class="py-12 text-center text-4xl font-bold">{title}</h1>

    <div class="space-y-4">
      <div
        id="reset-alert"
        role="alert"
        class="alert alert-soft w-fit mx-auto hidden"
      >
        <span id="reset-alert-message"></span>
      </div>

      <form id="reset-form" class="hidden space-y-4">
      <label class="input input-primary flex w-full items-center gap-2">
        <Icon class="h-4 w-4 opacity-50" name="pixelarticons:lock" />
        <input
          id="reset-new-password"
          type="password"
          class="grow"
          placeholder="Nuova password"
          minlength="8"
          required
        />
      </label>

      <label class="input input-primary flex w-full items-center gap-2">
        <Icon class="h-4 w-4 opacity-50" name="pixelarticons:lock" />
        <input
          id="reset-confirm-password"
          type="password"
          class="grow"
          placeholder="Conferma password"
          minlength="8"
          required
        />
      </label>

      <div class="flex justify-center">
        <button
          id="reset-submit"
          type="submit"
          class="btn btn-primary disabled:text-primary-content/50 uppercase"
        >
          Reimposta Password
        </button>
      </div>
    </form>
    </div>
  </div>
</Layout>

<script>
  import { authClient } from "@src/lib/authClient";

  const token = new URLSearchParams(window.location.search).get("token");
  const error = new URLSearchParams(window.location.search).get("error");

  const form = document.getElementById("reset-form") as HTMLFormElement;
  const alertBox = document.getElementById("reset-alert") as HTMLElement;
  const alertMessage = document.getElementById("reset-alert-message") as HTMLElement;

  const alertStyles = {
    error: "alert-error",
    success: "alert-success",
  };

  function showAlert(message: string, style: "error" | "success") {
    alertBox.classList.remove("hidden", "alert-error", "alert-success");
    alertBox.classList.add(alertStyles[style]);
    alertMessage.textContent = message;
  }

  if (error || !token) {
    showAlert("Il link di reset non è valido o è scaduto.", "error");
  } else {
    form.classList.remove("hidden");

    form.addEventListener("submit", async (e) => {
      e.preventDefault();

      const newPassword = (document.getElementById("reset-new-password") as HTMLInputElement).value;
      const confirmPassword = (document.getElementById("reset-confirm-password") as HTMLInputElement).value;

      if (newPassword !== confirmPassword) {
        showAlert("Le password non corrispondono.", "error");
      } else {
        const submitBtn = document.getElementById("reset-submit") as HTMLButtonElement;
        submitBtn.disabled = true;

        const { error: resetError } = await authClient.resetPassword({
          newPassword,
          token,
        });

        if (resetError) {
          showAlert(resetError.message ?? "Errore durante il reset della password.", "error");
          submitBtn.disabled = false;
        } else {
          form.classList.add("hidden");
          showAlert("Password reimpostata con successo! Ora puoi effettuare il login.", "success");
        }
      }
    });
  }
</script>
