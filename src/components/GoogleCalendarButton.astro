---
import Config from "@src/config/general.json";
---

<link
  href="https://calendar.google.com/calendar/scheduling-button-script.css"
  rel="stylesheet"
/>
<script
  is:inline
  src="https://calendar.google.com/calendar/scheduling-button-script.js"
  async></script>
<script
  is:inline
  data-gc-url={Config.googleCalendar.url}
  data-gc-cta={Config.googleCalendar.cta}
>
  var gcUrl = document.currentScript.dataset.gcUrl;
  var gcCta = document.currentScript.dataset.gcCta;
  (function () {
    var target = document.currentScript;
    var parent = target.parentElement;
    window.addEventListener("load", function () {
      calendar.schedulingButton.load({
        url: gcUrl,
        color: "#ff972a",
        label: gcCta,
        target,
      });
      parent?.addEventListener("click", function (e) {
        var el =
          e.target && e.target.closest ? e.target.closest("button, a") : null;
        if (el && window.gtag) {
          window.gtag("event", "calendar_open", {});
        }
      });
    });
  })();
  window.calendar = window.calendar || {};
</script>
