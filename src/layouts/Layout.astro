---
export interface Props {
  title?: string;
  description?: string;
  ogType?: string;
  ogImage?: string;
  ogImageAlt?: string;
  noindex?: boolean;
  frontmatter?: Props;
}

import "@fontsource/chakra-petch";
import "@fontsource/vt323";
import "@src/assets/css/main.css";
import "animate.css";
import Alert from "@src/components/Alert.astro";
import BackToTop from "@src/components/BackToTop.astro";
import Footer from "@src/components/Footer.astro";
import JsonLd from "@src/components/JsonLd.astro";
import LoginModal from "@src/components/LoginModal.astro";
import Navbar from "@src/components/Navbar.astro";
import TawktoWidget from "@src/components/TawktoWidget.astro";
import BaseModal from "@src/components/vue/BaseModal.vue";
import RadioMenu from "@src/components/vue/RadioMenu.vue";
import Zight from "@src/components/Zight.astro";
import Config from "@src/config/general.json";
import { SEO } from "astro-seo";

const {
  title = null,
  description = Config.description,
  ogType = "website",
  ogImage = Config.url + "/images/sharepreview.png",
  ogImageAlt = "Website Header",
  noindex = false,
} = Astro.props.frontmatter || Astro.props;

const {
  IUBENDA_SITE_ID,
  IUBENDA_POLICY_ID,
  GOOGLE_TAG_MANAGER_ID,
  TAWKTO_WIDGET_URL,
} = import.meta.env;

const canonical = Astro.url.href;

const typeOptinScript =
  IUBENDA_POLICY_ID && IUBENDA_SITE_ID ? "text/plain" : "text/javascript";

const fullTitle = title
  ? ogType == "article"
    ? title + " | " + Config.title
    : Config.title + " | " + title
  : Config.title + " | " + Config.motto;

const openGraph = {
  basic: {
    title: title ?? Config.title,
    type: ogType,
    image: ogImage,
    url: canonical,
  },
  image: {
    alt: ogImageAlt,
  },
};
---

<!doctype html>
<html lang="it" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />

    <SEO
      title={fullTitle}
      description={description}
      canonical={canonical}
      openGraph={openGraph}
      noindex={noindex}
    />

    <JsonLd />

    <link rel="icon" type="image/x-icon" href="/favicon.ico" />

    <link
      rel="alternate"
      type="application/rss+xml"
      title={`${Config.title + " | " + Config.motto}`}
      href={`${Config.url}/rss.xml`}
    />

    {
      GOOGLE_TAG_MANAGER_ID && (
        <script data-gtmid={GOOGLE_TAG_MANAGER_ID}>
          (function(w,d,s,l,i){
            w[l]=w[l]||[];w[l].push({'gtm.start':new Date().getTime(),event:'gtm.js'});
            var f=d.getElementsByTagName(s)[0],j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';
            j.async=true;
            j.src='https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
          })(window,document,'script','dataLayer',document.currentScript.dataset.gtmid);
        </script>
      )
    }

    <script src="@src/lib/authManager.ts"></script>
  </head>
  <body class="font-sans">
    <Navbar />
    <main class="mb-32 pt-16">
      <Alert />
      <slot />
    </main>
    <Footer />

    <RadioMenu client:only="vue" />

    <BackToTop />

    <BaseModal client:only="vue" />

    <LoginModal />

    <Zight />

    {
      TAWKTO_WIDGET_URL && (
        <TawktoWidget
          class="_iub_cs_activate-inline"
          type={typeOptinScript}
          data-cookieconsent="preferences, statistics"
          data-iub-purposes="2,4"
          data-widget={TAWKTO_WIDGET_URL}
        />
      )
    }
  </body>
</html>
